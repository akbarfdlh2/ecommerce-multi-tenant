APP_NAME="AFDA eCommerce"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# MongoDB - Central Database
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_USERNAME=ecommerce_user
MONGODB_PASSWORD=ecommerce_pass
MONGODB_CENTRAL_DB=ecommerce_central

# Cache / Session
CACHE_STORE=array
SESSION_DRIVER=array
SESSION_LIFETIME=120

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
